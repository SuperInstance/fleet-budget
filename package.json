    "db:init:remote": "wrangler d1 execute fleet-budget --remote --file=schema.sql",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250101.0",
    "typescript": "^5.7.0",
    "wrangler": "^3.100.0"
  }
}
