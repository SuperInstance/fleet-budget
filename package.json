{
  "name": "fleet-budget",
  "version": "1.0.0",
  "description": "D1-backed event-sourced ledger enforcing the conservation law γ + η ≤ C",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create fleet-budget",
